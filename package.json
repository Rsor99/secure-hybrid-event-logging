{
  "name": "secure-hybrid-event-logging",
  "version": "1.0.0",
  "description": "Research-grade logging benchmark: DB vs Private Chain vs Public Chain vs Hybrid",
  "main": "dist/server.js",
  "type": "commonjs",
  "scripts": {
    "build": "tsc",
    "start": "node dist/server.js",
    "dev": "ts-node-dev --respawn --transpile-only src/api/server.ts",
    "migrate": "ts-node src/infrastructure/database/migrate.ts",
    "experiment:all-24": "bash scripts/run-experiments.sh",
    "exp:db-postgres": "ts-node src/bench/runner.ts --db=postgres --strategy=database_only",
    "exp:db-mongo": "ts-node src/bench/runner.ts --db=mongo --strategy=database_only",
    "exp:chain-ethereum": "ts-node src/bench/runner.ts --chain=ethereum --strategy=public_chain",
    "exp:chain-exonum": "ts-node src/bench/runner.ts --chain=exonum --strategy=private_chain",
    "exp:hybrid-pg-ethereum": "ts-node src/bench/runner.ts --db=postgres --chain=ethereum --strategy=hybrid_public",
    "exp:hybrid-pg-exonum": "ts-node src/bench/runner.ts --db=postgres --chain=exonum --strategy=hybrid_private",
    "exp:hybrid-mongo-ethereum": "ts-node src/bench/runner.ts --db=mongo --chain=ethereum --strategy=hybrid_public",
    "exp:hybrid-mongo-exonum": "ts-node src/bench/runner.ts --db=mongo --chain=exonum --strategy=hybrid_private",
    "exp:batch-pg-ethereum": "ts-node src/bench/runner.ts --db=postgres --chain=ethereum --strategy=hybrid_public_batch",
    "exp:batch-pg-exonum": "ts-node src/bench/runner.ts --db=postgres --chain=exonum --strategy=hybrid_private_batch",
    "exp:batch-mongo-ethereum": "ts-node src/bench/runner.ts --db=mongo --chain=ethereum --strategy=hybrid_public_batch",
    "exp:batch-mongo-exonum": "ts-node src/bench/runner.ts --db=mongo --chain=exonum --strategy=hybrid_private_batch"
  },
  "dependencies": {
    "amqplib": "^1.0.3",
    "axios": "^1.6.2",
    "crypto-js": "^4.2.0",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "json2csv": "^6.0.0-alpha.2",
    "mongodb": "^7.2.0",
    "pg": "^8.11.3",
    "uuid": "^14.0.0"
  },
  "devDependencies": {
    "@nomicfoundation/hardhat-chai-matchers": "^2.1.0",
    "@nomicfoundation/hardhat-ethers": "^3.1.3",
    "@nomicfoundation/hardhat-ignition": "^0.15.16",
    "@nomicfoundation/hardhat-ignition-ethers": "^0.15.17",
    "@nomicfoundation/hardhat-network-helpers": "^1.1.2",
    "@nomicfoundation/hardhat-toolbox": "^5.0.0",
    "@nomicfoundation/hardhat-verify": "^2.1.3",
    "@nomicfoundation/ignition-core": "^0.15.15",
    "@typechain/ethers-v6": "^0.5.1",
    "@typechain/hardhat": "^9.1.0",
    "@types/amqplib": "^0.10.8",
    "@types/chai": "^4.3.20",
    "@types/crypto-js": "^4.2.1",
    "@types/express": "^4.17.21",
    "@types/mocha": "^10.0.10",
    "@types/node": "^20.10.0",
    "@types/pg": "^8.10.9",
    "@types/uuid": "^9.0.7",
    "chai": "^4.5.0",
    "ethers": "^6.10.0",
    "hardhat": "^2.22.1",
    "hardhat-gas-reporter": "^1.0.10",
    "solidity-coverage": "^0.8.17",
    "ts-node": "^10.9.1",
    "ts-node-dev": "^2.0.0",
    "typechain": "^8.3.2",
    "typescript": "^5.3.2"
  }
}
