# Server
PORT=3000
NODE_ENV=development

# ── PostgreSQL (required) ─────────────────────────────────────────────────────
PG_HOST=localhost
PG_PORT=5432
PG_NAME=secure_hybrid_event_logging
PG_USER=postgres
PG_PASSWORD=your_password_here
PG_POOL_SIZE=20

# ── MongoDB (required) ────────────────────────────────────────────────────────
MONGO_URI=mongodb://localhost:27017
MONGO_DB_NAME=secure_hybrid_event_logging
MONGO_POOL_SIZE=20

# ── Ethereum Sepolia — Public Chain (required) ────────────────────────────────
ETH_RPC_URL=https://ethereum-sepolia-rpc.publicnode.com
ETH_PRIVATE_KEY=0x...
ETH_LOG_CONTRACT=0x...
ETH_HASH_CONTRACT=0x...
ETH_BATCH_CONTRACT=0x...
ETH_CONFIRMATION_BLOCKS=3

# ── Exonum — Private Chain (required) ─────────────────────────────────────────
EXONUM_NODE_URL=http://localhost:8200
EXONUM_PUBLIC_KEY=...
EXONUM_SECRET_KEY=...
# Service IDs and names are fixed by the Exonum node config (defaults shown)
EXONUM_LOG_SERVICE_ID=100
EXONUM_LOG_SERVICE_NAME=log-service
EXONUM_HASH_SERVICE_ID=101
EXONUM_HASH_SERVICE_NAME=hash-service
EXONUM_BATCH_SERVICE_ID=102
EXONUM_BATCH_SERVICE_NAME=batch-service

# ── Misc (optional) ───────────────────────────────────────────────────────────
EXPORT_DIR=./results
